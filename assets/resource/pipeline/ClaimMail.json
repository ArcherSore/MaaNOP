{
    "ClaimMailEntry": {
        "next": [ "ClickOnMail" ]
    },
    "ClickOnMail": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "mail/mail.png",
                "roi": [ 1169, 53, 113, 109 ]
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "PreciseClick"
            }
        },
        "focus": {
            "Node.Action.Succeeded": "开始领取邮件附件"
        },
        "next": "WaitMailAttachmentButton"
    },
    "WaitMailAttachmentButton": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [ "mail/attachments.png", "mail/noattachments.png" ],
                "roi": [ 775, 563, 65, 32 ],
                "threshold": 0.75
            }
        },
        "next": [ "ClickOnAttachments", "NoAttachments" ]
    },
    "ClickOnAttachments": {
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [ 801, 567, 32, 12 ],
                "method": 40,
                "lower": [ 90, 80, 40 ],
                "upper": [ 110, 255, 255 ],
                "count": 110
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "PreciseClick"
            }
        },
        "pre_delay": 100,
        "next": "MailClaimAll"
    },
    "MailClaimAll": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "mail/claimall.png",
                "roi": [ 755, 519, 98, 67 ]
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "PreciseClick"
            }
        },
        "focus": {
            "Node.Action.Succeeded": "成功领取邮件附件"
        },
        "next": "MailDeleteAll"
    },
    "MailDeleteAll": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "mail/deleteall.png",
                "roi": [ 676, 518, 98, 68 ]
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "PreciseClick"
            }
        },
        "next": "CloseAttachments"
    },
    "NoAttachments": {
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [ 801, 567, 32, 12 ],
                "method": 40,
                "lower": [ 0, 0, 40 ],
                "upper": [ 179, 35, 180 ],
                "count": 200
            }
        },
        "focus": {
            "Node.Recognition.Succeeded": "无需领取邮件附件"
        },
        "next": "CloseAttachments"
    },
    "CloseAttachments": {
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 27
            }
        },
        "next": "CloseMail"
    },
    "CloseMail": {
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 27
            }
        },
        "next": [ "ClaimLevelEntry", "Login" ]
    }
}
